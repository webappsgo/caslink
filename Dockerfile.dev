# Development Dockerfile for Caslink URL Shortener
FROM golang:1.22-alpine AS builder

# Install development dependencies
RUN apk add --no-cache \
    git \
    ca-certificates \
    tzdata \
    sqlite \
    gcc \
    musl-dev

WORKDIR /app

# Copy go mod and sum files
COPY go.mod go.sum ./

# Download dependencies
RUN go mod download

# Copy source code
COPY . .

# Build the application with CGO enabled for SQLite
RUN CGO_ENABLED=1 GOOS=linux go build -a -installsuffix cgo -o caslink cmd/main.go

# Development stage
FROM alpine:latest

# Install runtime dependencies
RUN apk --no-cache add \
    ca-certificates \
    tzdata \
    sqlite \
    curl

WORKDIR /app

# Copy the binary from builder stage
COPY --from=builder /app/caslink .

# Create directories for data and configuration
RUN mkdir -p /var/lib/caslink /etc/caslink

# Expose the default port
EXPOSE 64000

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
    CMD ./caslink health || exit 1

# Set default environment variables for development
ENV CASLINK_DATABASE_TYPE=sqlite \
    CASLINK_DATABASE_PATH=/var/lib/caslink/caslink.db \
    CASLINK_SERVER_HOST=0.0.0.0 \
    CASLINK_SERVER_PORT=64000 \
    CASLINK_LOG_LEVEL=debug \
    CASLINK_LOG_FORMAT=json

# Run the application
CMD ["./caslink", "webui"]